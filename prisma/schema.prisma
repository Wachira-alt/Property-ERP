generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                 @id @default(cuid())
  name             String
  email            String                 @unique
  password         String
  role             UserRole
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  deletedAt        DateTime?
  assignedContacts Contact[]              @relation("AgentContacts")
  markedPayments   LedgerEntry[]          @relation("MarkedByAccountant")
  notes            Note[]
  extensions       ReservationExtension[]
  otpCodes         OtpCode[]
  sessions         UserSession[]
  loginLogs        LoginLog[]
  auditLogs        AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  actorId     String?
  actorName   String
  actorRole   String
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_codes")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("user_sessions")
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("login_logs")
}

model Project {
  id          String     @id @default(cuid())
  name        String
  location    String?
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  contacts    Contact[]
  unitTypes   UnitType[]

  @@map("projects")
}

model UnitType {
  id          String   @id @default(cuid())
  name        String
  description String?
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
  units       Unit[]

  @@index([projectId])
  @@map("unit_types")
}

model Unit {
  id            String                 @id @default(cuid())
  name          String
  floor         String?
  status        UnitStatus             @default(AVAILABLE)
  reservedUntil DateTime?
  unitTypeId    String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  opportunity   Opportunity?
  extensions    ReservationExtension[]
  unitType      UnitType               @relation(fields: [unitTypeId], references: [id])

  @@index([unitTypeId])
  @@index([status])
  @@map("units")
}

model Contact {
  id          String       @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String
  projectId   String
  agentId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  agent       User         @relation("AgentContacts", fields: [agentId], references: [id])
  project     Project      @relation(fields: [projectId], references: [id])
  notes       Note[]
  contactDocuments ContactDocument[]
  opportunity Opportunity?

  @@index([projectId])
  @@index([agentId])
  @@map("contacts")
}

model Opportunity {
  id            String         @id @default(cuid())
  contactId     String         @unique
  unitId        String?        @unique
  stage         PipelineStage  @default(GREEN)
  agreedPrice   Decimal?       @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  closedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  documents     Document[]
  ledgerEntries LedgerEntry[]
  contact       Contact        @relation(fields: [contactId], references: [id])
  unit          Unit?          @relation(fields: [unitId], references: [id])

  @@index([stage])
  @@index([unitId])
  @@map("opportunities")
}

model LedgerEntry {
  id             String        @id @default(cuid())
  opportunityId  String
  description    String
  amount         Decimal       @db.Decimal(12, 2)
  dueDate        DateTime
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  paymentRef     String?
  markedById     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  receiptFileKey String?
  receiptUrl     String?
  markedBy       User?         @relation("MarkedByAccountant", fields: [markedById], references: [id])
  opportunity    Opportunity   @relation(fields: [opportunityId], references: [id])

  @@index([opportunityId])
  @@index([dueDate])
  @@index([status])
  @@map("ledger_entries")
}

model Document {
  id            String       @id @default(cuid())
  opportunityId String
  type          DocumentType
  fileName      String
  fileUrl       String
  fileKey       String
  uploadedAt    DateTime     @default(now())
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id])

  @@index([opportunityId])
  @@index([type])
  @@map("documents")
}

model Note {
  id        String   @id @default(cuid())
  contactId String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  contact   Contact  @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@map("notes")
}

model ReservationExtension {
  id             String   @id @default(cuid())
  unitId         String
  grantedById    String
  previousExpiry DateTime
  newExpiry      DateTime
  reason         String?
  createdAt      DateTime @default(now())
  grantedBy      User     @relation(fields: [grantedById], references: [id])
  unit           Unit     @relation(fields: [unitId], references: [id])

  @@index([unitId])
  @@map("reservation_extensions")
}

model Campaign {
  id          String               @id @default(cuid())
  subject     String
  body        String
  sentAt      DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  audience    String               @default("ALL")
  sentCount   Int                  @default(0)
  attachments CampaignAttachment[]

  @@map("campaigns")
}

model CampaignAttachment {
  id         String   @id @default(cuid())
  campaignId String
  fileName   String
  fileUrl    String
  fileKey    String
  mimeType   String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_attachments")
}

enum UserRole {
  ADMIN
  SALES
  ACCOUNTANT
  HR
  GENERAL_MANAGER
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum PipelineStage {
  GREEN
  AMBER
  CLOSED
  EXPIRED
  CANCELLED
  PAST
}

enum PaymentMethod {
  CASH
  MORTGAGE
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum DocumentType {
  NATIONAL_ID
  KRA_PIN
  OFFER_LETTER_UNSIGNED
  OFFER_LETTER_SIGNED
  BOOKING_RECEIPT
}
model ContactDocument {
  id          String   @id @default(cuid())
  contactId   String
  fileName    String
  fileUrl     String
  fileKey     String
  mimeType    String
  uploadedBy  String
  uploaderName String
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_documents")
}