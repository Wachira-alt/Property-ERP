generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- AUTHENTICATION MODELS ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(SALES)
  accounts      Account[]
  sessions      Session[]
  sourcedContacts Contact[] @relation("SourcingAgent")
}

enum UserRole {
  ADMIN
  GENERAL_MANAGER
  ACCOUNTANT
  SALES
  CONSTRUCTION
  HUMAN_RESOURCE
}

// --- INVENTORY MODELS ---

model Project {
  id        String     @id @default(cuid())
  name      String
  location  String
  unitTypes UnitType[]
  contacts  Contact[]  @relation("ProjectInterest")
  createdAt DateTime   @default(now())
}

model UnitType {
  id        String   @id @default(cuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  units     Unit[]
}

model Unit {
  id             String     @id @default(cuid())
  unitNumber     String
  unitTypeId     String
  unitType       UnitType   @relation(fields: [unitTypeId], references: [id], onDelete: Cascade)
  status         UnitStatus @default(AVAILABLE)
  completionDate DateTime?
  holdExpiresAt  DateTime?  // 7-day timer
  opportunities  Opportunity[]
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
}

// --- PIPELINE & SALES MODELS ---

model Contact {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  
  // KYC & Documents
  idNumber          String?
  kraPin            String?
  idDocumentUrl     String?
  kraDocumentUrl    String?
  signedOfferUrl    String?
  bookingFeeUrl     String?
  
  // Stage 1 & 2: Interests
  interestedProjectId String?
  project             Project? @relation("ProjectInterest", fields: [interestedProjectId], references: [id])
  interestedUnitId    String?  // FIX: Added for Green Stage tracking
  
  // Agency
  sourcingAgentId   String?
  sourcingAgent     User?    @relation("SourcingAgent", fields: [sourcingAgentId], references: [id])

  opportunities     Opportunity[]
  createdAt         DateTime @default(now())
}

model Opportunity {
  id            String            @id @default(cuid())
  contactId     String
  contact       Contact           @relation(fields: [contactId], references: [id])
  unitId        String
  unit          Unit              @relation(fields: [unitId], references: [id])
  agreedPrice   Decimal           @db.Decimal(20, 2)
  
  // NEW: Store the payment method for the Offer Letter
  paymentMethod String?           // e.g., "CASH", "MORTGAGE", "INSTALLMENTS"
  
  status        OpportunityStatus @default(LEAD)
  ledgerEntries LedgerEntry[]
  createdAt     DateTime          @default(now())
}

enum OpportunityStatus {
  LEAD
  RESERVED
  CLOSED
  CANCELLED
}

model LedgerEntry {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  description   String?
  amount        Decimal     @db.Decimal(20, 2)
  dueDate       DateTime
  paidDate      DateTime?
  type          EntryType
  status        EntryStatus @default(PENDING)
  reference     String?
  createdAt     DateTime    @default(now())
}

enum EntryType {
  DEPOSIT
  INSTALLMENT
  PAYMENT
}

enum EntryStatus {
  PENDING
  PAID
  OVERDUE
}