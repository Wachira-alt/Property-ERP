generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. PROJECTS (The Parent Registry)
model Project {
  id         String     @id @default(uuid())
  name       String     @unique
  location   String?
  properties Property[]
  createdAt  DateTime   @default(now())
}

// 2. USERS (RBAC & AGENTS)
model User {
  id            String        @id @default(uuid())
  email         String        @unique
  name          String?
  role          Role          @default(SALES)
  createdAt     DateTime      @default(now())
  
  assignedDeals Opportunity[] 
  contacts      Contact[]     
  logs          AuditLog[]    
}

// 3. PROPERTIES (Inventory Control)
model Property {
  id            String         @id @default(uuid())
  unitNumber    String         @unique 
  
  projectId     String         // Linked to Project Model
  project       Project        @relation(fields: [projectId], references: [id])
  
  cashPrice     Decimal        @db.Decimal(10, 2)
  mortgagePrice Decimal        @db.Decimal(10, 2)
  status        PropertyStatus @default(AVAILABLE)
  
  opportunity   Opportunity?   
}

// 4. CONTACTS (Master Registry)
model Contact {
  id            String        @id @default(uuid())
  firstName     String
  lastName      String
  email         String        @unique
  phone         String
  type          ContactType   @default(LEAD)
  source        String?       
  createdAt     DateTime      @default(now())
  isSubscribed  Boolean       @default(true)

  agentId       String?       
  agent         User?         @relation(fields: [agentId], references: [id])
  opportunities Opportunity[]
  notes         Note[]
  documents     Document[]
}

// 5. OPPORTUNITIES (The Pipeline)
model Opportunity {
  id              String          @id @default(uuid())
  status          DealStage       @default(RESERVED) // UPDATED: Starts as Reserved
  financingMethod FinancingMethod @default(CASH) 
  
  contactId       String
  contact         Contact         @relation(fields: [contactId], references: [id])
  
  propertyId      String          @unique 
  property        Property        @relation(fields: [propertyId], references: [id])
  
  agentId         String
  agent           User            @relation(fields: [agentId], references: [id])

  ledger          LedgerEntry[]
  
  createdAt       DateTime        @default(now())
}

// 6. LEDGER (Revenue Ops)
model LedgerEntry {
  id            String          @id @default(uuid())
  opportunityId String
  opportunity   Opportunity     @relation(fields: [opportunityId], references: [id])
  
  type          TransactionType 
  amount        Decimal         @db.Decimal(10, 2)
  status        PaymentStatus   @default(PENDING)
  
  dueDate       DateTime?       
  paidDate      DateTime?
  
  reference     String?         
  createdAt     DateTime        @default(now())
}

// 7. AUDIT TRAILS
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   
  timestamp DateTime @default(now())
}

// ============================================================================
// ENUMS (Strict Business Logic)
// ============================================================================

enum Role {
  ADMIN
  SALES
  ACCOUNTS
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  BLOCKED
}

enum ContactType {
  LEAD
  ACTIVE_BUYER
  PAST_CLIENT // Triggers the Newsletter
}

enum DealStage {
  RESERVED   // Booking fee paid, awaiting full deposit
  ACTIVE     // Down payment secured, healthy pipeline
  AT_RISK    // Overdue on installments
  CANCELLED  // Deal fell through / Refunded
  COMPLETED  // 100% Paid. Deal Closed.
}

enum TransactionType {
  INVOICE
  PAYMENT
  REFUND
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum FinancingMethod {
  CASH
  MORTGAGE
}

model Campaign {
  id          String   @id @default(cuid())
  subject     String
  audience    String
  sentCount   Int      @default(0)
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
}

model Note {
  id          String    @id @default(cuid())
  content     String   
  isTask      Boolean   @default(false)
  isCompleted Boolean   @default(false)
  dueDate     DateTime? // <-- NEW: Schedules the follow-up
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Document {
  id          String   @id @default(cuid())
  name        String   // e.g., "Client_ID.pdf"
  fileData    String   // Stores the file itself
  mimeType    String   // e.g., "application/pdf" or "image/png"
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  uploadedAt  DateTime @default(now())
}